# API base URL. Defaults to `/api` (where MSW intercepts). Point this at a real
# API to swap backends, e.g. VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=/api

# Mock backend toggle (opt-out). Unset → MSW in dev, real API in prod.
#   VITE_API_MOCK=false  → run dev against a real API (see docs/how-to/08-real-backend)
#   VITE_API_MOCK=true   → force the mock on (e.g. a prod demo build)
# VITE_API_MOCK=false

# Display name used in the UI shell.
VITE_APP_NAME=React Redux Seed
